{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "node_modules/.tmp/tsbuild/main.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "node_modules/.tmp/tsbuild/main",
    "types": ["node", "vite/client"]
  },
  "include": ["src/main/**/*.ts"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
