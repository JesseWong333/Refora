{
  "name": "refora",
  "version": "0.1.0",
  "description": "Local-first PDF literature manager",
  "main": "out/main/index.js",
  "author": "Refora",
  "license": "MIT",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build:agent-runner": "sh scripts/build-agent-runner.sh",
    "dev": "npm run build:agent-runner && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "npm run build:agent-runner && electron-vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e:workspace-card": "electron-vite build && playwright test tests/e2e/workspace-card-pointer.spec.ts --workers=1",
    "package": "npm run build && electron-builder --mac",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.3",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.10.1",
    "@lobehub/ui": "^5.19.0",
    "@napi-rs/canvas": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-virtual": "^3.10.0",
    "antd": "^6.5.0",
    "antd-style": "^4.1.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "electron-log": "^5.1.0",
    "fast-xml-parser": "^5.9.3",
    "i18next": "^26.3.6",
    "katex": "^0.16.47",
    "langchain": "^1.5.3",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.5.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
