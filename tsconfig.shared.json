{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "node_modules/.tmp/tsbuild/shared.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "node_modules/.tmp/tsbuild/shared",
    "types": []
  },
  "include": ["src/shared/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "tests/**"]
}
